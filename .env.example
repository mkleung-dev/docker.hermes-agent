# Hermes Agent Configuration
# 
# Copy this file to .env and modify values as needed:
#   cp .env.example .env
#
# The Makefile will automatically load variables from .env when present.
# Default values are used if .env does not exist or a variable is not specified.

# Service name in docker-compose.yaml
SERVICE_NAME=hermes

# Docker container name (visible in 'docker ps')
CONTAINER_NAME=hermes

# Docker image to use
# Format: registry/image:tag
# Latest tag is used if not specified
IMAGE=nousresearch/hermes-agent

# Docker volume name for persistent data storage
# Data is stored at /opt/data inside the container
DATA_VOLUME=hermes-data

# Container restart policy
# Options:
#   no                - Do not automatically restart container
#   always            - Always restart if it stops (even if stopped manually)
#   unless-stopped    - Always restart unless container was explicitly stopped
#   on-failure        - Restart only if it exits with non-zero exit status
RESTART_POLICY=unless-stopped

# Optional: Maximum retry count when using on-failure restart policy
# RESTART_MAX_RETRIES=5

# Optional: Delay between restart attempts (seconds)
# RESTART_DELAY=5
